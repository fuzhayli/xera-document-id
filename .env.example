TURSO_DATABASE_URL=libsql://your-database-your-org.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token
PORT=32780
NODE_ENV=development
DISABLE_PUBLIC_SIGNUP=false
APP_TIME_ZONE=Europe/Istanbul

# For an empty production database, set this once in Render to create the first admin.
# Existing admin passwords are not overwritten.
INITIAL_ADMIN_PASSWORD=replace_with_a_strong_private_password

# Optional for migration. Defaults to the sibling dated SQLite backup folder.
SQLITE_DB_PATH=../2026-06-03 SQLite Based - XERA Document ID Generator/data/xera-document-id.sqlite
